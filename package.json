{
  "name": "@bethinkpl/reorder",
  "version": "1.1.0",
  "description": "Customized version of @reorderjs/reorder.",
  "license": "MIT",
  "files": [
    ".medusa/server"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./workflows": "./.medusa/server/src/workflows/index.js",
    "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
    "./modules/*": "./.medusa/server/src/modules/*/index.js",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./*": "./.medusa/server/src/*.js",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    }
  },
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "medusa plugin:develop",
    "prepublishOnly": "medusa plugin:build",
    "test:integration:http": "npm run test:db:up && npm run test:integration:http:run; npm run test:db:down",
    "test:integration:http:run": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:integration:modules": "npm run test:db:up && npm run test:integration:modules:run; npm run test:db:down",
    "test:integration:modules:run": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:db:up": "docker compose -f docker-compose.test.yml --env-file .env.test up -d --wait ",
    "test:db:down": "docker compose -f docker-compose.test.yml --env-file .env.test down"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@medusajs/admin-sdk": "2.12.4",
    "@medusajs/cli": "2.12.4",
    "@medusajs/framework": "2.12.4",
    "@medusajs/icons": "2.12.4",
    "@medusajs/medusa": "2.12.4",
    "@medusajs/test-utils": "2.12.4",
    "@medusajs/ui": "4.0.25",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@swc/core": "^1.7.28",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9",
    "@types/luxon": "^3",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "eslint": "^10.3.0",
    "jest": "^29.7.0",
    "jsonwebtoken": "^9.0.3",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.59.1",
    "vite": "^5.2.11",
    "yalc": "^1.0.0-pre.53"
  },
  "peerDependencies": {
    "@medusajs/admin-sdk": "2.12.4",
    "@medusajs/cli": "2.12.4",
    "@medusajs/framework": "2.12.4",
    "@medusajs/icons": "2.12.4",
    "@medusajs/medusa": "2.12.4",
    "@medusajs/test-utils": "2.12.4",
    "@medusajs/ui": "4.0.25"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@4.4.1",
  "dependencies": {
    "luxon": "^3.7.2"
  }
}
